---
import { projects } from '../../config/projects.json';
---

<h2 class="text-2xl font-bold mb-4">Projects</h2>
{
    projects.map(project=>(
        <div class="flex text-center mb-8 md:text-left">
         <div class="flex-1 gap-y-3 ">   
             <h2 class="font-bold text-2xl my-4">{project.title}</h2>
            <p>{project.description}</p>
            <button class="bg-indigo-500 px-3 py-2 hover:bg-indigo-400">
                More Info
            </button>
            </div>
            <div class="flex-1">
                <img src={project.image} alt={project.title} class="w-72 m-auto rounded-lg mb-4" />
            </div>
        </div>

    )
    )
}
