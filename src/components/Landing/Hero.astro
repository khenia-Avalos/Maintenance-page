---
// Hero para Montero Maintenance LLC
// Componente con animaciones desde animations.css
---

<section id="home" class="pt-32 pb-20 bg-gradient-to-br from-white via-[#FAF0E6] to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      
      <!-- Texto con animación de caída desde arriba -->
      <div class="animate-fall">
        <div class="inline-block mb-4">
          <div class="w-12 h-0.5 bg-[#D2B48C]"></div>
        </div>
        
        <h1 class="text-5xl md:text-6xl font-bold text-[#1A1A1A] leading-tight mb-6">
          Montero
          <span class="text-[#6B7280]">Maintenance</span>
          <span class="text-sm block text-[#9CA3AF] font-normal mt-1">LLC</span>
        </h1>
        
        <p class="text-lg text-[#4B5563] mb-6 leading-relaxed animate-fade-up delay-200">
          Year-round property maintenance experts offering professional power washing, residential and commercial cleaning, expert lawn care, and reliable snow removal — keeping your property safe, beautiful, and well-maintained in every season.
        </p>
      </div>
      
      <!-- Imágenes con fade in escalonado -->
      <div class="space-y-4">
        <img 
          src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600" 
          alt="Property maintenance" 
          class="animate-fade delay-100 rounded-2xl shadow-2xl w-full h-64 object-cover"
        />
        <div class="grid grid-cols-2 gap-4">
          <img 
            src="https://images.unsplash.com/photo-1596436889106-be35e843f974?w=300" 
            alt="Lawn care" 
            class="animate-fade delay-300 rounded-xl shadow-md w-full h-32 object-cover"
          />
          <img 
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=300" 
            alt="Cleaning" 
            class="animate-fade delay-500 rounded-xl shadow-md w-full h-32 object-cover"
          />
        </div>
      </div>
      
    </div>
  </div>
</section>