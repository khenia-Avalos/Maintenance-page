---
// Sección de servicios - 4 servicios principales
const services = [
  {
    icon: "/plant.svg",
    title: "🔥 LAWN CARE 🔥",
    description: "✨ ¡CAMBIO DRASTICO! Este texto es NUEVO y diferente ✨",
    color: "bg-[#FF6B6B]",
    hoverColor: "hover:bg-[#FF5252]",
    textColor: "text-white"
  },
  {
    icon: "/cleaning.svg",
    title: "💎 CLEANING SERVICES 💎",
    description: "⚡ OTRO CAMBIO GRANDE - Servicios de limpieza profesional ⚡",
    color: "bg-[#4ECDC4]",
    hoverColor: "hover:bg-[#3DBEB5]",
    textColor: "text-white"
  },
  {
    icon: "/snow.svg",
    title: "❄️ SNOW REMOVAL ❄️",
    description: "🌟 CAMBIO NOTABLE - Remoción de nieve 24/7 🌟",
    color: "bg-[#45B7D1]",
    hoverColor: "hover:bg-[#3BA3BB]",
    textColor: "text-white"
  },
  {
    icon: "/plant.svg",
    title: "💧 POWER WASHING 💧",
    description: "🎯 CAMBIO IMPORTANTE - Lavado a presión profesional 🎯",
    color: "bg-[#F9CA24]",
    hoverColor: "hover:bg-[#F6C017]",
    textColor: "text-gray-900"
  }
];
---

<section class="py-20 bg-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Encabezado con cambios drásticos -->
    <div class="text-center mb-12">
      <span class="text-[#FF6B6B] font-bold text-lg uppercase tracking-wider">🚨 CAMBIO DRASTICO ACTIVADO 🚨</span>
      <h2 class="text-5xl md:text-6xl font-bold text-white mt-4">🔥 THIS IS A TEST 🔥</h2>
      <div class="w-40 h-1 bg-[#FF6B6B] mx-auto mt-4"></div>
      <p class="text-[#4ECDC4] mt-6 max-w-2xl mx-auto text-lg font-bold">
        ⚡ SI VES ESTE TEXTO, LOS CAMBIOS FUNCIONARON ⚡
      </p>
    </div>
    
    <!-- Grid de servicios con borde blanco para destacar -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service, index) => (
        <div class={`text-center p-8 rounded-3xl transition-all duration-300 hover:scale-105 hover:shadow-2xl ${service.color} ${service.hoverColor} border-4 border-white`}>
          <div class="w-24 h-24 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
            <img 
              src={service.icon} 
              alt={service.title} 
              class="w-16 h-16"
            />
          </div>
          <h3 class={`text-2xl font-extrabold mb-3 ${service.textColor}`}>{service.title}</h3>
          <p class={`${service.textColor} opacity-95 leading-relaxed font-medium`}>{service.description}</p>
          <a href="#contact" class={`inline-block mt-6 px-6 py-2 rounded-full font-bold transition-all duration-300 ${service.textColor === 'text-white' ? 'bg-black hover:bg-gray-800' : 'bg-black hover:bg-gray-800'} text-white`}>
            🔥 CLICK AQUÍ 🔥
          </a>
        </div>
      ))}
    </div>
    
    <!-- Botón CTA con cambio drástico -->
    <div class="text-center mt-16">
      <a href="#contact" class="inline-block bg-[#FF6B6B] text-white px-10 py-4 rounded-full hover:bg-[#FF5252] transition-all duration-300 font-bold text-lg shadow-xl hover:scale-105">
        🚨 GET FREE ESTIMATE - CAMBIO DRASTICO 🚨
      </a>
    </div>
    
  </div>
</section>