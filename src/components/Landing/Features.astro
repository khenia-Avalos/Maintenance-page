---
import features from "../../config/features.json"
---

<h1 class="text-center font-bold text-5xl mt-10">Features</h1>

<div class=" grid md:grid-cols-3 gap-4 p-4"     >
    {features.map(feature => (
        <div class="bg-zinc-900 p-10 rounded-2xl mt-10">
            <h2 class="text-3xl font-bold">{feature.title}</h2>
            <p class="mt-4 text-zinc-300">{feature.description}</p>
        </div>
    ))}
    
</div>