---
import features from "../../config/features.json"
---

<h1 class="text-center font-bold text-5xl mt-10 text-[rgba(230,226,226,0.77)]">Why Choose Us</h1>

<div class="grid md:grid-cols-3 gap-4 p-4">
    {features.map(feature => (
        <div class="bg-[#FAF0E6] p-10 rounded-2xl mt-10 shadow-md hover:shadow-xl transition-shadow duration-300">
            <h2 class="text-3xl font-bold text-[#1A1A1A] text-center">{feature.title}</h2>
            <p class="mt-4 text-[#4B5563]">{feature.description}</p>
        </div>
    ))}
</div>