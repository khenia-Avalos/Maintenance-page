---
import faqs from "../../config/faqs.json"
---

<section class="py-24 bg-gradient-to-br from-white via-[#FAF0E6]/30 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Encabezado Luxury -->
    <div class="text-center mb-16">
      <div class="inline-block mb-3">
        <span class="text-[#D2B48C] font-light text-sm uppercase tracking-widest">FAQ</span>
        <div class="w-full h-px bg-[#D2B48C] mt-1"></div>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#1A1A1A] mt-4 font-serif">
        Frequently Asked<span class="text-[#D2B48C]"> Questions</span>
      </h2>
      <div class="w-16 h-0.5 bg-[#D2B48C] mx-auto mt-6 mb-4"></div>
      <p class="text-[#4B5563] mt-4 max-w-2xl mx-auto text-lg font-light">
        Everything you need to know about our premium services
      </p>
    </div>
    
    <!-- Grid de preguntas - Luxury Style -->
    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <div class="group">
          <button 
            class="faq-question w-full text-left px-8 py-5 flex justify-between items-center gap-4 bg-white border border-[#E8E3DA] rounded-2xl hover:border-[#D2B48C] hover:shadow-lg transition-all duration-300"
            data-index={index}
          >
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-[#FAF0E6] group-hover:bg-[#D2B48C] transition-colors duration-300 flex items-center justify-center text-sm font-bold text-[#6B7280] group-hover:text-white">
                {index + 1}
              </div>
              <span class="text-lg font-semibold text-[#1A1A1A] group-hover:text-[#D2B48C] transition-colors duration-300">
                {faq.question}
              </span>
            </div>
            <span class="faq-icon text-[#D2B48C] transition-transform duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </span>
          </button>
          
          <div class="faq-answer hidden mt-2 mb-2" data-index={index}>
            <div class="bg-[#FAF0E6] rounded-2xl p-8 ml-12 border-l-4 border-[#D2B48C] shadow-md">
              <p class="text-[#4B5563] leading-relaxed text-base">
                {faq.answer}
              </p>
              <div class="mt-4 pt-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-[#D2B48C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-xs text-[#6B7280] font-light">Montero Maintenance</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- CTA final Luxury -->
    <div class="text-center mt-16 pt-8 pb-4">
      <div class="inline-block p-8 bg-[#FAF0E6] rounded-3xl shadow-sm">
        <p class="text-[#6B7280] mb-3 text-sm uppercase tracking-wide font-medium">Still have questions?</p>
        <p class="text-[#1A1A1A] mb-6 text-lg font-light max-w-md">We're here to help you with anything you need</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-[#1A1A1A] text-white px-8 py-3 rounded-full hover:bg-[#333333] transition-all duration-300 font-semibold group">
          <span>Contact Us</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
    
  </div>
</section>

<script>
  // Funcionalidad del acordeón
  const questions = document.querySelectorAll('.faq-question');
  
  questions.forEach(button => {
    button.addEventListener('click', () => {
      const index = button.getAttribute('data-index');
      const answer = document.querySelector(`.faq-answer[data-index="${index}"]`);
      const icon = button.querySelector('.faq-icon svg');
      
      if (!answer || !icon) return;
      
      // Cerrar otras respuestas abiertas
      const allAnswers = document.querySelectorAll('.faq-answer');
      const allIcons = document.querySelectorAll('.faq-question .faq-icon svg');
      
      allAnswers.forEach(ans => {
        if (ans !== answer && ans.classList.contains('block')) {
          ans.classList.remove('block');
          ans.classList.add('hidden');
        }
      });
      
      allIcons.forEach(ic => {
        if (ic !== icon && ic.classList.contains('rotate-180')) {
          ic.classList.remove('rotate-180');
        }
      });
      
      // Alternar la respuesta actual
      if (answer.classList.contains('hidden')) {
        answer.classList.remove('hidden');
        answer.classList.add('block');
        icon.classList.add('rotate-180');
      } else {
        answer.classList.remove('block');
        answer.classList.add('hidden');
        icon.classList.remove('rotate-180');
      }
    });
  });
</script>

<style>
  .faq-icon svg {
    transition: transform 0.3s ease;
  }
  
  .rotate-180 {
    transform: rotate(180deg);
  }
  
  .faq-answer {
    animation: fadeIn 0.4s ease-out;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>