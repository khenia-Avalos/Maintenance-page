---
import Layout from "../Layouts/Layout.astro"
import Header from "../components/Landing/Header.astro"
import Button from "../components/button.astro"
---

<Layout title="Contact Us">
    <Header />
    
    <!-- Sección Hero de Contact -->
    <section class="pt-32 pb-20 bg-gradient-to-br from-white via-[#FAF0E6] to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <span class="text-[#6B7280] font-semibold text-sm uppercase tracking-wide">Get In Touch</span>
          <h1 class="text-5xl md:text-7xl font-bold text-[#1A1A1A] mt-4">Contact Us</h1>
          <div class="w-24 h-0.5 bg-[#D2B48C] mx-auto mt-6 mb-6"></div>
          <p class="text-xl text-[#4B5563] max-w-3xl mx-auto">
            Experience the pinnacle of property maintenance. Let us elevate your space.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Sección principal de contacto -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-16">
          
          <!-- Formulario de contacto -->
          <div>
            <h2 class="text-3xl font-bold text-[#1A1A1A] mb-8">Send a Message</h2>

            <form action="https://monteromaintenance.com/send-mail.php" method="POST" class="space-y-6">
              
              <!-- Tipo de solicitud -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Request Type *</label>
                <select 
                  name="request_type"
                  id="request_type"
                  required
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white"
                >
                  <option value="budget">📋 Request a Free Estimate</option>
                  <option value="schedule">📅 Schedule a Service (I have a quote)</option>
                </select>
              </div>

              <!-- Campos básicos -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Full Name *</label>
                <input 
                  type="text" 
                  name="name"
                  required
                  placeholder="John Anderson"
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white placeholder:text-gray-400"
                />
              </div>
              
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Email Address *</label>
                <input 
                  type="email" 
                  name="email"
                  required
                  placeholder="john.anderson@example.com"
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white placeholder:text-gray-400"
                />
              </div>
              
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Phone Number</label>
                <input 
                  type="tel" 
                  name="phone"
                  placeholder="+1 (555) 123-4567"
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white placeholder:text-gray-400"
                />
              </div>
              
              <!-- Servicio -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Service Needed *</label>
                <select 
                  name="service"
                  required
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white"
                >
                  <option value="">Select a service</option>
                  <option value="Lawn Care">🌿 Lawn Care</option>
                  <option value="Cleaning Services">🧼 Cleaning Services</option>
                  <option value="Snow Removal">❄️ Snow Removal</option>
                  <option value="Power Washing">💧 Power Washing</option>
                </select>
              </div>
              
              <!-- Campo de fecha (se muestra SOLO si eligió "schedule") -->
              <div id="date_field" style="display: none;">
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Preferred Date</label>
                <input 
                  type="date" 
                  name="preferred_date"
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white"
                />
              </div>
              
              <!-- Mensaje -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2 text-sm uppercase tracking-wide">Message / Details *</label>
                <textarea 
                  rows="5" 
                  name="message"
                  required
                  placeholder="Please describe your property and what services you need..."
                  class="w-full px-5 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-all duration-300 text-[#1A1A1A] bg-white placeholder:text-gray-400 resize-none"
                ></textarea>
              </div>
              
              <button 
                type="submit"
                class="w-full bg-[#1A1A1A] text-white px-8 py-4 rounded-lg hover:bg-[#333333] transition-all duration-300 font-semibold"
              >
                Send Message
              </button>
            </form>
          </div>
          
          <!-- Información de contacto -->
          <div class="bg-[#FAF0E6] rounded-3xl p-8 md:p-10">
            <h2 class="text-3xl font-bold text-[#1A1A1A] mb-8">Contact Information</h2>
            
            <div class="space-y-8">
              <!-- Teléfono -->
              <div class="flex items-start gap-5 group">
                <div class="w-12 h-12 bg-[#D2B48C] rounded-full flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1 text-sm uppercase tracking-wide">Phone</h3>
                  <p class="text-[#4B5563] text-lg">+1 (555) 123-4567</p>
                </div>
              </div>
              
              <!-- Email -->
              <div class="flex items-start gap-5 group">
                <div class="w-12 h-12 bg-[#D2B48C] rounded-full flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1 text-sm uppercase tracking-wide">Email</h3>
                  <p class="text-[#4B5563] text-lg">concierge@monteromaintenance.com</p>
                </div>
              </div>
              
              <!-- Horario -->
              <div class="flex items-start gap-5 group">
                <div class="w-12 h-12 bg-[#D2B48C] rounded-full flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1 text-sm uppercase tracking-wide">Business Hours</h3>
                  <p class="text-[#4B5563]">Monday - Friday: 8:00 AM - 6:00 PM</p>
                  <p class="text-[#4B5563]">Saturday: 9:00 AM - 4:00 PM</p>
                  <p class="text-[#4B5563]">Sunday: Closed</p>
                </div>
              </div>
            </div>
            
            <!-- Divider -->
            <div class="w-full h-px bg-[#D2B48C]/30 my-8"></div>
            
            <!-- Nota -->
            <div class="text-center">
              <p class="text-[#6B7280] text-sm italic">
                "White-glove service for discerning homeowners"
              </p>
            </div>
          </div>
          
        </div>
      </div>
    </section>
  
    <!-- Call to Action - Emergency -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
        <div class="bg-[#FAF0E6] rounded-3xl p-12">
          <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A] mb-4">Need Emergency Service?</h2>
          <div class="w-16 h-0.5 bg-[#D2B48C] mx-auto my-6"></div>
          <p class="text-[#4B5563] mb-8 text-lg">Available 24/7 for urgent property maintenance needs</p>
          <Button href="tel:+15551234567" text="Call Now: +1 (555) 123-4567" />
        </div>
      </div>
    </section>
    
</Layout>

<!-- Script para mostrar/ocultar campos según la selección -->
<script>
  const requestType = document.getElementById('request_type');
  const dateField = document.getElementById('date_field');

  function toggleFields() {
    if (requestType && requestType.value === 'schedule') {
      if (dateField) dateField.style.display = 'block';
    } else {
      if (dateField) dateField.style.display = 'none';
    }
  }

  if (requestType) {
    requestType.addEventListener('change', toggleFields);
    toggleFields();
  }
</script>