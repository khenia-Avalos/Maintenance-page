---
import Layout from "../Layouts/Layout.astro"
import Header from "../components/Landing/Header.astro"
import Button from "../components/button.astro"
---

<Layout title="Contact Us">
    <Header />
    
    <!-- Sección Hero de Contact -->
    <section class="pt-32 pb-16 bg-gradient-to-br from-white via-[#FAF0E6] to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <span class="text-[#6B7280] font-semibold text-sm uppercase tracking-wide">Get In Touch</span>
          <h1 class="text-4xl md:text-6xl font-bold text-[#1A1A1A] mt-2">Contact Us</h1>
          <div class="w-20 h-0.5 bg-[#D2B48C] mx-auto mt-4 mb-6"></div>
          <p class="text-xl text-[#4B5563] max-w-3xl mx-auto">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Sección principal de contacto -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12">
          
          <!-- Formulario de contacto -->
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] mb-6">Send Us a Message</h2>

<form action="https://monteromaintenance.com/send-mail.php" method="POST" class="space-y-4">              <!-- Tipo de solicitud -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">¿Qué necesitas? *</label>
                <select 
                  name="request_type"
                  id="request_type"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                >
                  <option value="budget">📋 Solicitar presupuesto gratuito</option>
                  <option value="schedule">📅 Reservar servicio (ya tengo presupuesto)</option>
                </select>
              </div>

              <!-- Campos básicos -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">Full Name *</label>
                <input 
                  type="text" 
                  name="name"
                  required
                  placeholder="Tu nombre completo"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                />
              </div>
              
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">Email *</label>
                <input 
                  type="email" 
                  name="email"
                  required
                  placeholder="tu@email.com"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                />
              </div>
              
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">Phone</label>
                <input 
                  type="tel" 
                  name="phone"
                  placeholder="(555) 123-4567"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                />
              </div>
              
              <!-- Servicio -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">Service Needed *</label>
                <select 
                  name="service"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                >
                  <option value="">Select a service</option>
                  <option value="Lawn Care">🌿 Lawn Care</option>
                  <option value="Cleaning Services">🧼 Cleaning Services</option>
                  <option value="Snow Removal">❄️ Snow Removal</option>
                  <option value="Power Washing">💧 Power Washing</option>
                </select>
              </div>
              
              <!-- Campo de fecha (se muestra SOLO si eligió "schedule") -->
              <div id="date_field" style="display: none;">
                <label class="block text-[#1A1A1A] font-medium mb-2">Fecha preferida para el servicio</label>
                <input 
                  type="date" 
                  name="preferred_date"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                />
              </div>
              
              <!-- Mensaje -->
              <div>
                <label class="block text-[#1A1A1A] font-medium mb-2">Message / Details *</label>
                <textarea 
                  rows="4" 
                  name="message"
                  required
                  placeholder="Cuéntanos más sobre lo que necesitas..."
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#D2B48C] focus:outline-none transition-colors text-[#1A1A1A] bg-white"
                ></textarea>
              </div>
              
              <Button type="submit" text="Send Message" />
            </form>
          </div>
          
          <!-- Información de contacto -->
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] mb-6">Contact Information</h2>
            
            <div class="space-y-6">
              <!-- Teléfono -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#FAF0E6] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#D2B48C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1">Phone</h3>
                  <p class="text-[#4B5563]">(555) 123-4567</p>
                  <p class="text-[#4B5563]">(555) 765-4321</p>
                </div>
              </div>
              
              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#FAF0E6] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#D2B48C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1">Email</h3>
                  <p class="text-[#4B5563]">info@monteromaintenance.com</p>
                  <p class="text-[#4B5563]">sales@monteromaintenance.com</p>
                </div>
              </div>
              
              <!-- Horario -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#FAF0E6] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#D2B48C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-[#1A1A1A] mb-1">Business Hours</h3>
                  <p class="text-[#4B5563]">Monday - Friday: 8am - 6pm</p>
                  <p class="text-[#4B5563]">Saturday: 9am - 4pm</p>
                  <p class="text-[#4B5563]">Sunday: Closed</p>
                  <p class="text-[#D2B48C] font-semibold mt-2">24/7 Emergency Service Available</p>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </section>
  
    <!-- Call to Action -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A] mb-4">Need Emergency Service?</h2>
        <p class="text-[#4B5563] mb-8">Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
        <Button href="tel:+5551234567" text="Call Now: (555) 123-4567" />
      </div>
    </section>
    
</Layout>

<!-- Script para mostrar/ocultar campos según la selección y manejar el envío -->
<script>
  const requestType = document.getElementById('request_type') as HTMLSelectElement | null;
  const dateField = document.getElementById('date_field') as HTMLDivElement | null;

  function toggleFields(): void {
    if (requestType && requestType.value === 'schedule') {
      if (dateField) dateField.style.display = 'block';
    } else {
      if (dateField) dateField.style.display = 'none';
    }
  }

  if (requestType) {
    requestType.addEventListener('change', toggleFields);
    toggleFields();
  }

  const form = document.querySelector('form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      const submitButton = (form.querySelector('button[type="submit"]') || form.querySelector('button')) as HTMLButtonElement | null;
      
      if (!submitButton) {
        console.error('Botón de enviar no encontrado');
        alert('Error: No se pudo procesar el formulario');
        return;
      }

      const originalButtonText = submitButton.textContent || 'Send Message';
      submitButton.textContent = 'Enviando...';
      submitButton.disabled = true;

      const formData = new FormData(form);

      try {
        const response = await fetch('/send-mail.php', {
          method: 'POST',
          body: formData
        });

        const result = await response.json() as { success?: boolean; message?: string; error?: string };

        if (response.ok && result.success) {
          alert(result.message);
          form.reset();
          if (requestType) requestType.value = 'budget';
          toggleFields();
        } else {
          alert(result.error || 'Hubo un error al enviar. Inténtalo de nuevo.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error de conexión. Por favor verifica tu conexión a internet.');
      } finally {
        submitButton.textContent = originalButtonText;
        submitButton.disabled = false;
      }
    });
  } else {
    console.error('Formulario no encontrado');
  }
</script>